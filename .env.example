DB_HOST=localhost
DB_PORT=5432
DB_USER=app
DB_PASSWORD=changeme
DB_NAME=chat
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
# Keys the usage ledger (run budget); generate with openssl rand -hex 32
USAGE_HASH_SECRET=changeme-generate-with-openssl-rand-hex-32
# Agent service base URL (default http://localhost:8081)
AGENT_URL=
# Optional DSN override
DATABASE_URL=
# Optional log level: debug, info, warn, error (default info)
LOG_LEVEL=
# Optional per-user rolling-24h run budget (default 20; over the limit returns 429)
RUNS_BUDGET_DAILY=
# Google Sign-In (the only login path)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OAuth client secret; the API exchanges the auth code for an id token with it
GOOGLE_CLIENT_SECRET=your-client-secret
# Same value, baked into the web image at build time (used by docker compose `make stack-up`)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: this email gets an unlimited daily run budget
OWNER_EMAIL=
# Optional: set to "true" to allow new account creation (closed by default)
SIGNUP_OPEN=
# Magic-link email (Resend); empty locally uses the fake mailer that logs links
RESEND_API_KEY=
# Verified Resend sender for sign-in links
MAGIC_LINK_FROM=login@lucek.ai
# Optional: attaches response feedback to the run's LangSmith trace (same key as agent/.env); empty keeps it DB-only
LANGSMITH_API_KEY=
