OPENROUTER_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="simple-deep-research"

# Default model/search settings, overridable per-role and per-run via LangGraph's
# `configurable` dict (see AgentConfig in src/config.py).
DEFAULT_MODEL=deepseek/deepseek-v4-flash
MAX_SEARCHES=5
